{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
        "@shared/*": ["../../shared/*"],
        "@server/*": ["../../services/shared-server/*"]
    }
  },
  "include": ["src/**/*", "../shared-server/**/*", "../../shared/**/*"]
}
