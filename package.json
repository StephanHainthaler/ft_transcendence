{
  "name": "ft_transcendence",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev": "dotenv -e ./env/.env.development -- concurrently -n frontend,api,user,auth,game_stats -c blue,violet,yellow,green \"npm:dev:frontend\" \"npm:dev:api\" \"npm:dev:user\" \"npm:dev:auth\" \"npm:dev:game_stats\" ",
    "dev:api": "npm run dev -w @ft_transcendence/api",
    "dev:auth": "npm run dev -w @ft_transcendence/auth",
    "dev:user": "npm run dev -w @ft_transcendence/user",
    "dev:game_stats": "npm run dev -w @ft_transcendence/game_stats",
    "dev:frontend": "npm run dev -w @ft_transcendence/frontend",
    "dev:frontend:test": "tsx --env-file=\"env/.env.development\" --test ./frontend/tests/*.test.ts",
    "build:docker:frontend": "vite build",
    "test:backend:api": "npm run test -w @ft_transcendence/api",
    "test:backend:database": "npm run test -w @ft_transcendence/database",
    "test:backend:game_stats": "npm run test -w @ft_transcendence/game_stats",
    "test:backend:user": "npm run test -w @ft_transcendence/user",
    "test:backend": "npm-run-all --continue-on-error test:backend:*",
    "docker:build:api": "npm run build -w @ft_transcendence/api",
    "clean:workspaces": "npm run clean --workspaces --if-present",
    "clean:root": "rm -rf node_modules",
    "clean:db": "rm -f services/**/db/*.db services/**/db/*.db-journal services/**/db/*.db-wal",
    "clean": "npm run clean:workspaces && npm run clean:root"
  },
  "devDependencies": {
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.557.0",
    "@sveltejs/kit": "^2.48.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.16",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "npm-run-all": "^4.1.5",
    "svelte-check": "^4.3.4",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tsx": "^4.20.6",
    "turbo": "^2.0.0",
    "tw-animate-css": "^1.4.0"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@sveltejs/adapter-node": "^5.5.2",
    "@tailwindcss/cli": "^4.1.16",
    "@types/node": "^24.10.0",
    "better-sqlite3": "^12.6.2",
    "concurrently": "^9.2.1",
    "fastify": "^5.7.4",
    "fastify-pino-pretty": "^5.2.0",
    "mkdirp": "^3.0.1",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "svelte": "^5.45.8",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.3.0",
    "undici": "^7.21.0",
    "vite": "^7.2.1"
  },
  "overrides": {
    "cookie": "^0.7.0"
  }
}
