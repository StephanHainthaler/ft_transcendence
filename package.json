{
  "name": "ft_transcendence",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "services/*",
    "shared"
  ],
  "scripts": {
    "dev": "dotenv -e ./env/.env.development -- concurrently -n frontend,api -c blue,red,yellow \"npm:dev:frontend\" \"npm:dev:api\"",
    "dev:api": "npm run dev -w @ft_transcendence/api",
    "dev:frontend": "cd frontend && vite",
    "dev:frontend:test": "concurrently -k -s first --hide 0 \"npm:dev:api\" \"wait-on tcp:3000 && tsx --env-file=./env/.env.development --test ./frontend/tests/*.test.ts\"",
    "build:docker:frontend": "vite build"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.16",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.20.6",
    "turbo": "^2.0.0"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.16",
    "@types/node": "^24.10.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.16",
    "typescript": "^5.3.0",
    "vite": "^7.2.1",
    "wait-on": "^9.0.1"
  }
}
